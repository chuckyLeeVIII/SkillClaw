# Copy this file to `.env` and fill in your real secrets locally.
# Do not commit the populated `.env` file.

# LLM API
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-api-key
EVOLVE_MODEL=your-model-name
JUDGE_MODEL=your-judge-model-name
EVOLVE_LLM_MAX_TOKENS=4096
EVOLVE_LLM_TEMPERATURE=0.4

# Evolve scheduling
EVOLVE_INTERVAL=600
EVOLVE_PORT=8787

# Storage backend
EVOLVE_STORAGE_BACKEND=oss
EVOLVE_STORAGE_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
EVOLVE_STORAGE_BUCKET=your-bucket-name
EVOLVE_STORAGE_ACCESS_KEY_ID=your-access-key-id
EVOLVE_STORAGE_SECRET_ACCESS_KEY=your-access-key-secret
EVOLVE_GROUP_ID=default

# Local output files
EVOLVE_HISTORY_LOG=evolve_history.jsonl
EVOLVE_PROCESSED_LOG=evolve_processed.json

# Optional integrations
GITHUB_TOKEN=
GH_TOKEN=
BRAVE_API_KEY=
